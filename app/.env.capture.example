# 캡처 파이프라인 전용 환경변수 (vibe-videos의 capture.ts가 .env.capture로 로드)
#
# 사용법:
#   cp app/.env.capture.example app/.env.capture
#   # 필요하면 값 수정
#   # vibe-videos의 .vibe-video.yml env_capture: app/.env.capture 가 이 파일을 주입
#
# 주의: 실제 .env.capture 는 gitignore 대상입니다. example 파일만 커밋하세요.

# 카카오 OAuth 리다이렉트를 건너뛰고 고정 데모 유저로 로그인 상태를 재현
NEXT_PUBLIC_MOCK_OAUTH=1

# Gemini API 호출을 고정 오사카 3박 4일 응답으로 대체 (네트워크/API 키 불필요)
NEXT_PUBLIC_MOCK_LLM=1
